# NovelForge 部署环境配置

# 前端访问端口 (宿主机访问地址)
FRONTEND_PORT=80

# 前端连接后端的 API 地址
# 留空：默认使用 Nginx 代理（推荐用于生产/Docker）
# 如果前端和后端部署在不同机器，请填写类似 http://your-ip:8000
VITE_BACKEND_URL=

# 后端 API 端口
BACKEND_PORT=8000

# 后端数据库 (SQLite) 宿主机存储目录
# 该目录下会生成 novelforge.db 文件
BACKEND_DATA_PATH=./backend/data

# 知识图谱配置
# 核心驱动：neo4j
KNOWLEDGE_GRAPH_PROVIDER=neo4j

NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# Neo4j 内部连接地址 (Docker 网络内使用 bolt://neo4j:7687)
NEO4J_URI=bolt://neo4j:7687

# Neo4j 数据持久化宿主机路径
NEO4J_DATA_PATH=./neo4j_data
NEO4J_LOGS_PATH=./neo4j_logs

# 启动时是否覆盖内置数据 (提示词等)
BOOTSTRAP_OVERWRITE=true

# --- 登录认证配置 ---
# 管理员进入后台的密码
ADMIN_PASSWORD=novel_forge_admin_123

# JWT 签名密钥 (建议修改为随机字符串以增强安全性)
SECRET_KEY=novelforge_default_secret_key_change_me
